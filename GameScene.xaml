<UserControl x:Class="TADprojekt.GameScene"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Viewbox Stretch="Uniform">
        <Grid Background="Black" Width="1920" Height="1080">
            <Border x:Name="GameBackground" Opacity="0">
                <Border.Background>
                    <ImageBrush ImageSource="/cover2.jpg" Stretch="UniformToFill" />
                </Border.Background>
            </Border>
            <Grid x:Name="GameProfiles" Opacity="0">
                <Border Width="380" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50" CornerRadius="15" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect x:Name="Player1Glow" Color="White" BlurRadius="40" ShadowDepth="0" Opacity="0" />
                    </Border.Effect>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5" Opacity="0.4">
                            <GradientStop Color="#0066ff" Offset="0.0" />
                            <GradientStop Color="Black" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <Border CornerRadius="10" Background="#333333">
                            <Image x:Name="Player1Icon" Width="180" Height="180" Stretch="UniformToFill" Margin="5">
                                <Image.Clip><EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90" /></Image.Clip>
                            </Image>
                        </Border>
                        <TextBlock x:Name="Player1Name" Text="Gracz 1" FontFamily="Franklin Gothic Heavy Cond" FontSize="50" Foreground="White" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="50,0,50,50">
                    <Button x:Name="Player1PlayCardButton" Content="ZAGRAJ" FontFamily="Franklin Gothic Heavy Cond" FontSize="40" Foreground="Gray" Background="#b3333333" BorderBrush="Gray" BorderThickness="3" Padding="20,10" Margin="0,0,0,10" Click="PlayCard1_Click" />
                    <TextBlock x:Name="Player1CardCounter" Text="Do Zagrania: 0 / 3" FontSize="30" Foreground="Gray" FontFamily="Franklin Gothic Medium Cond" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Border CornerRadius="10" ClipToBounds="True" BorderThickness="0" Width="264" Height="370" MouseLeftButtonDown="Player1Card_MouseDown" Cursor="Hand">
                        <Image x:Name="Player1CardImage" Source="/reverse.png" Stretch="UniformToFill" Opacity="0.8" />
                    </Border>
                </StackPanel>
                <Border Width="380" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="50" CornerRadius="15" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect x:Name="Player2Glow" Color="White" BlurRadius="40" ShadowDepth="0" Opacity="0" />
                    </Border.Effect>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5" Opacity="0.4">
                            <GradientStop Color="Black" Offset="0.0" />
                            <GradientStop Color="#ff1111" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <Border CornerRadius="10" Background="#333333">
                            <Image x:Name="Player2Icon" Width="180" Height="180" Stretch="UniformToFill" Margin="5">
                                <Image.Clip><EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90" /></Image.Clip>
                            </Image>
                        </Border>
                        <TextBlock x:Name="Player2Name" Text="Gracz 2" FontFamily="Franklin Gothic Heavy Cond" FontSize="50" Foreground="White" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="50,0,50,50">
                    <Button x:Name="Player2PlayCardButton" Content="ZAGRAJ" FontFamily="Franklin Gothic Heavy Cond" FontSize="40" Foreground="Gray" Background="#b3333333" BorderBrush="Gray" BorderThickness="3" Padding="20,10" Margin="0,0,0,10" Click="PlayCard2_Click" />
                    <TextBlock x:Name="Player2CardCounter" Text="Do Zagrania: 0 / 3" FontSize="30" Foreground="Gray" FontFamily="Franklin Gothic Medium Cond" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Border CornerRadius="10" ClipToBounds="True" BorderThickness="0" Width="264" Height="370" MouseLeftButtonDown="Player2Card_MouseDown" Cursor="Hand">
                        <Image x:Name="Player2CardImage" Source="/reverse.png" Stretch="UniformToFill" Opacity="0.8" />
                    </Border>
                </StackPanel>
            </Grid>
            <Border x:Name="GameBoardContainer" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#b3222222" BorderBrush="#ededed" BorderThickness="4" CornerRadius="10" Padding="15">
                <Grid>
                    <UniformGrid x:Name="GameBoard" Rows="5" Columns="5" Width="770" Height="770" />
                    <Canvas x:Name="EffectsCanvas" Width="770" Height="770" IsHitTestVisible="False" ClipToBounds="False" />
                </Grid>
            </Border>
            <Button x:Name="SurrenderButton" Content="PODDAJ SIĘ" FontFamily="Franklin Gothic Heavy Cond" FontSize="30" Foreground="LightGray" Background="#b3333333" BorderBrush="LightGray" BorderThickness="3" Padding="20,5" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,0" Opacity="0" Click="SurrenderButton_Click" Panel.ZIndex="10"/>
            <TextBlock x:Name="StartAnnouncementText" Text="Zaczyna: test" Opacity="0" FontFamily="Franklin Gothic Heavy Cond" FontSize="80" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="WinAnnouncementText" Text="Zwyciężył: test" Opacity="0" FontFamily="Franklin Gothic Heavy Cond" FontSize="100" Foreground="Gold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="2000" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <Border x:Name="CardPreviewOverlay" Background="#cc000000" Visibility="Collapsed" MouseLeftButtonDown="CardPreviewOverlay_MouseDown" Panel.ZIndex="100">
                <Border CornerRadius="20" ClipToBounds="True" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#ededed" BorderThickness="5" Width="642" Height="900">
                    <Image x:Name="LargeCardPreviewImage" Stretch="UniformToFill" />
                </Border>
            </Border>
            <Border x:Name="RandomCardPreviewOverlay" Background="#cc000000" Visibility="Collapsed" MouseLeftButtonDown="RandomCardPreviewOverlay_MouseDown" Panel.ZIndex="101">
                <Border CornerRadius="20" ClipToBounds="True" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#ededed" BorderThickness="5" Width="1400" Height="900" Background="#f0222222" MouseLeftButtonDown="InnerOverlay_MouseDown">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                        <UniformGrid x:Name="AllCardsGrid" Columns="5" Margin="20" VerticalAlignment="Top" />
                    </ScrollViewer>
                </Border>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>
