<UserControl x:Class="TADprojekt.GameScene"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Viewbox Stretch="Uniform">
        <Grid Background="Black" Width="1920" Height="1080">
            <Border x:Name="MenuBackground" Opacity="0">
                <Border.Background>
                    <ImageBrush ImageSource="/cover2.jpg" Stretch="UniformToFill" Opacity="0.0" />
                </Border.Background>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>