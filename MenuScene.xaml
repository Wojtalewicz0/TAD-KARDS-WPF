<UserControl x:Class="TADprojekt.MenuScene"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Franklin Gothic Heavy Cond" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="#ededed" />
            <Setter Property="BorderThickness" Value="4" />
            <Setter Property="Padding" Value="40,15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D1D1D" />
                                <Setter  TargetName="ButtonBorder" Property="BorderBrush" Value="#777777" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Viewbox Stretch="Uniform">
        <Grid Background="Black"  Width="1920" Height="1080">
            <Border x:Name="TitleBackground" Opacity="0">
                <Border.Background>
                    <ImageBrush ImageSource="/cover1.jpg" Stretch="UniformToFill" />
                </Border.Background>
            </Border>
            <Border x:Name="MenuBackground" Opacity="0">
                <Border.Background>
                    <ImageBrush ImageSource="/cover4.jpg" Stretch="UniformToFill" />
                </Border.Background>
            </Border>
            <TextBlock x:Name="SpaceText" Text="Naciśnij spację by kontynuować" Foreground="White" FontSize="30" HorizontalAlignment="Center"
                VerticalAlignment="Bottom" Margin="0,0,0,130" Opacity="0">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="1" />
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="ShaderText" Text="Kompilowanie shaderów..." Foreground="White" FontSize="25" HorizontalAlignment="Left" Margin="30,0,0,30"
                VerticalAlignment="Bottom" Opacity="0" />
            <TextBlock x:Name="VersionText" Text="Version: 0.4 12-04-2026" Foreground="White" FontSize="19" HorizontalAlignment="Left" Margin="12,8,0,0"
                VerticalAlignment="Top" Opacity="0" />
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="EpilepsiaText1" Text="OSTRZEŻENIE PRZED EPILEPSJĄ FOTOGENNĄ" TextAlignment="Center" Width="640" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,0,0,15" Opacity="0" />
                <TextBlock x:Name="EpilepsiaText2" Text="TA APLIKACJA MOŻE ZAWIERAĆ MIGOCZĄCE ŚWIATŁA, SZYBKIE ZMIANY OBRAZÓW ORAZ WZORY WIZUALNE, KTÓRE U NIEKTÓRYCH OSÓB MOGĄ WYWOŁAĆ ATAK PADACZKI FOTOSENSYTYWNEJ.&#x0a;&#x0a;JEŚLI KIEDYKOLWIEK DOŚWIADCZYŁEŚ ATAKU PADACZKI, UTRATY PRZYTOMNOŚCI LUB INNYCH OBJAWÓW NEUROLOGICZNYCH, SKONSULTUJ SIĘ Z LEKARZEM PRZED ROZPOCZĘCIEM ROZGRYWKI.&#x0a;&#x0a;NATYCHMIAST PRZERWIJ GRĘ I SKONTAKTUJ SIĘ Z LEKARZEM, JEŚLI PODCZAS KORZYSTANIA Z APLIKACJI WYSTĄPIĄ TYPOWE OBJAWY." TextAlignment="Justify" TextWrapping="Wrap" Width="640" Foreground="White" FontSize="23" Opacity="0" />
            </StackPanel>
            <TextBlock x:Name="CopyrightText" Text="Wszelkie prawa zastrzeżone&#x0a;2026" TextAlignment="Center" Foreground="White" FontSize="24" HorizontalAlignment="Center"
                VerticalAlignment="Center" Opacity="0" />
            <Image x:Name="LogoImage" Source="/logo.png" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0" Stretch="Uniform" 
                Width="640" RenderTransformOrigin="0.5, 0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="1.0" ScaleY="1.0" />
                </Image.RenderTransform>
            </Image>
            <Image x:Name="LogoImage2" Source="/logo2.png" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0" Stretch="Uniform" Margin="0,180,0,0"
                Width="610">
            </Image>
            <Image x:Name="LogoImage3" Source="/logo3.png" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0" Stretch="Uniform" Margin="0,0,0,0"
                Width="650">
                <Image.RenderTransform>
                    <TranslateTransform x:Name="MoveImage" Y="650" />
                </Image.RenderTransform>
            </Image>
            <Grid x:Name="ButtonsContainer" HorizontalAlignment="Center" VerticalAlignment="Bottom" Width="1344" Height="108" Margin="0,0,0,140">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="MenuButton1" Style="{StaticResource MenuButtonStyle}" Click="MenuButton1_Click" Grid.Column="0" Content="KONFIGURACJA" FontSize="42" Margin="20,0,20,0" Opacity="0">
                    <Button.RenderTransform>
                        <TranslateTransform x:Name="MoveButton1" Y="150" />
                    </Button.RenderTransform>
                </Button>
                <Button x:Name="MenuButton2" Style="{StaticResource MenuButtonStyle}" Click="MenuButton2_Click" Grid.Column="1" Content="GRAJ" FontSize="55" Margin="20,0,20,0" Opacity="0">
                    <Button.RenderTransform>
                        <TranslateTransform x:Name="MoveButton2" Y="150" />
                    </Button.RenderTransform>
                </Button>
                <Button x:Name="MenuButton3" Style="{StaticResource MenuButtonStyle}" Grid.Column="2"  Click="MenuButton3_Click" Content="USTAWIENIA" FontSize="48" Margin="20,0,20,0" Opacity="0">
                    <Button.RenderTransform>
                        <TranslateTransform x:Name="MoveButton3" Y="150" />
                    </Button.RenderTransform>
                </Button>
            </Grid>      
            <Border x:Name="SettingsPanel" Width="1280" Height="720" Background="#f0222222" BorderBrush="#ededed" BorderThickness="5" CornerRadius="10" Opacity="0" IsHitTestVisible="False" Margin="0,0,0,170">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="1000">
                    <TextBlock Text="USTAWIENIA" FontFamily="Franklin Gothic Medium Cond" FontSize="70" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,40" />
                    
                    <!-- NADANA NAZWA DO MODYFIKACJI Z POZIOMU C# -->
                    <TextBlock x:Name="VolumeText" Text="Głośność: 100%" FontFamily="Franklin Gothic Medium Cond" FontSize="40" Foreground="White" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    
                    <Slider x:Name="VolumeSlider" ValueChanged="VolumeSlider_ValueChanged" MouseLeave="VolumeSlider_MouseLeave" PreviewMouseLeftButtonUp="VolumeSlider_MouseUp" Minimum="0" Maximum="100" Value="100" IsSnapToTickEnabled="True" TickFrequency="1" Height="40" Margin="0,0,0,40"/>
                    <CheckBox x:Name="RandomStartCheckBox" Content="Zawsze zaczyna Gracz 1 (wyłączone: zaczyna losowy Gracz)" Foreground="White" FontSize="10" FontFamily="Franklin Gothic Medium Cond" HorizontalAlignment="Center" VerticalContentAlignment="Center" Margin="0,0,0,60" Click="RandomStartCheckBox_Click">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="3" ScaleY="3" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    
                    <Button x:Name="CreditsButton" Style="{StaticResource MenuButtonStyle}" Content="AUTORZY" FontSize="40" Click="CreditsButton_Click" Margin="300,0,300,20"/>
                    <Button x:Name="ExitButton" Style="{StaticResource MenuButtonStyle}" Content="WYJŚCIE" FontSize="40" Click="ExitButton_Click" Margin="300,0,300,20"/>
                    <Button x:Name="CloseSettingsButton" Style="{StaticResource MenuButtonStyle}" Content="POWRÓT" FontSize="40" Click="CloseSettingsButton_Click" Margin="300,0,300,0"/>
                </StackPanel>
            </Border>   
            <Border x:Name="ConfigPanel" Width="1280" Height="720" Background="#f0222222" BorderBrush="#ededed" BorderThickness="5" CornerRadius="10" Opacity="0" IsHitTestVisible="False" Margin="0,0,0,170">
                <Grid Margin="50">
                    <!-- GŁÓWNY WIDOK KONFIGURACJI -->
                    <Grid x:Name="ConfigMainView" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="KONFIGURACJA" FontFamily="Franklin Gothic Heavy Cond" FontSize="70" Foreground="White" HorizontalAlignment="Center" />       
                        <Grid Grid.Row="1" Margin="0,40,0,40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderThickness="4" CornerRadius="10" Margin="0,0,20,0" MouseLeftButtonDown="Player1_Click" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#800077FF" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#200077FF" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="Player1NameText" Text="GRACZ 1" FontFamily="Franklin Gothic Medium Cond" Foreground="White" FontSize="45" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                                    <Image x:Name="Player1IconImage" Width="260" Stretch="UniformToFill">
                                        <Image.Clip>
                                            <EllipseGeometry Center="130,130" RadiusX="130" RadiusY="130" />
                                        </Image.Clip>
                                    </Image>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" BorderThickness="4" CornerRadius="10" Margin="20,0,0,0" MouseLeftButtonDown="Player2_Click" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#80FF2222" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#20FF2222" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="Player2NameText" Text="GRACZ 2" FontFamily="Franklin Gothic Medium Cond" Foreground="White" FontSize="45" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                                    <Image x:Name="Player2IconImage" Width="260" Stretch="UniformToFill">
                                        <Image.Clip>
                                            <EllipseGeometry Center="130,130" RadiusX="130" RadiusY="130" />
                                        </Image.Clip>
                                    </Image>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Button x:Name="CloseConfigButton" Grid.Row="2" Style="{StaticResource MenuButtonStyle}" Content="POWRÓT" FontSize="20" Click="CloseConfigButton_Click" HorizontalAlignment="Center" Width="400"/>
                    </Grid>
                    <Grid x:Name="PlayerEditView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="PlayerEditTitle" Text="EDYCJA GRACZA" FontFamily="Franklin Gothic Heavy Cond" FontSize="60" Foreground="White" HorizontalAlignment="Center" />
                        <TextBox x:Name="PlayerNameInput" MaxLength="13" Grid.Row="1" FontSize="40" FontFamily="Franklin Gothic Medium Cond" Background="#333333" Foreground="White" BorderBrush="#ededed" BorderThickness="3" HorizontalAlignment="Center" Width="600" Margin="0,20,0,20" TextAlignment="Center" Padding="10"/>
                        
                        <Border Grid.Row="2" BorderBrush="#555555" BorderThickness="2" Margin="0,10,0,20">
                            <!-- Zwiększono rozmiar ikon do 180x180 i zmniejszono margines do Margin="3,0" -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="SelectIcon1" Source="/icon1.png" Width="180" Height="180" Stretch="UniformToFill" Margin="3,0" Cursor="Hand" MouseLeftButtonDown="SelectIcon_Click">
                                    <Image.Clip><EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90" /></Image.Clip>
                                </Image>
                                <Image x:Name="SelectIcon2" Source="/icon2.png" Width="180" Height="180" Stretch="UniformToFill" Margin="3,0" Cursor="Hand" MouseLeftButtonDown="SelectIcon_Click">
                                    <Image.Clip><EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90" /></Image.Clip>
                                </Image>
                                <Image x:Name="SelectIcon3" Source="/icon3.png" Width="180" Height="180" Stretch="UniformToFill" Margin="3,0" Cursor="Hand" MouseLeftButtonDown="SelectIcon_Click">
                                    <Image.Clip><EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90" /></Image.Clip>
                                </Image>
                                <Image x:Name="SelectIcon4" Source="/icon4.png" Width="180" Height="180" Stretch="UniformToFill" Margin="3,0" Cursor="Hand" MouseLeftButtonDown="SelectIcon_Click">
                                    <Image.Clip><EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90" /></Image.Clip>
                                </Image>
                                <Image x:Name="SelectIcon5" Source="/icon5.png" Width="180" Height="180" Stretch="UniformToFill" Margin="3,0" Cursor="Hand" MouseLeftButtonDown="SelectIcon_Click">
                                    <Image.Clip><EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90" /></Image.Clip>
                                </Image>
                                <Image x:Name="SelectIcon6" Source="/icon6.png" Width="180" Height="180" Stretch="UniformToFill" Margin="3,0" Cursor="Hand" MouseLeftButtonDown="SelectIcon_Click">
                                    <Image.Clip><EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90" /></Image.Clip>
                                </Image>
                            </StackPanel>
                        </Border>            
                        
                        <Button x:Name="SavePlayerButton" Grid.Row="3" Style="{StaticResource MenuButtonStyle}" Content="ZATWIERDŹ" FontSize="25" Click="SavePlayerButton_Click" HorizontalAlignment="Center" Width="400"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>